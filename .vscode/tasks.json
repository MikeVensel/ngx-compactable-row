  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "start",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Changes detected"
          },
          "endsPattern": {
            "regexp": "bundle generation (complete|failed)"
          }
        }
      }
    },
    {
      "type": "npm",
      "script": "test",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Changes detected"
          },
          "endsPattern": {
            "regexp": "bundle generation (complete|failed)"
          }
        }
      }
    },
    {
      "label": "kill ng serve",
      "type": "shell",
      "command": "/bin/sh",
      "args": ["-c", "fuser -k 4200/tcp >/dev/null 2>&1 || true"],
      "linux": {
        "command": "/bin/sh",
        "args": ["-c", "fuser -k 4200/tcp >/dev/null 2>&1 || true"]
      },
      "problemMatcher": []
    },
    {
      "label": "kill ng test",
      "type": "shell",
      "command": "/bin/sh",
      "args": ["-c", "fuser -k 9876/tcp >/dev/null 2>&1 || true"],
      "linux": {
        "command": "/bin/sh",
        "args": ["-c", "fuser -k 9876/tcp >/dev/null 2>&1 || true"]
      },
      "problemMatcher": []
    }
  ]
}
