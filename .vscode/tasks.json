{
  // For more information, visit: https://go.microsoft.com/fwlink/?LinkId=733558
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "start",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Changes detected"
          },
          "endsPattern": {
            "regexp": "bundle generation (complete|failed)"
          }
        }
      }
    },
    {
      "type": "npm",
      "script": "test",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Changes detected"
          },
          "endsPattern": {
            "regexp": "bundle generation (complete|failed)"
          }
        }
      }
    },
    {
      "label": "kill ng serve",
      "type": "shell",
      "command": "/bin/sh",
      "args": ["-c", "fuser -k 4200/tcp >/dev/null 2>&1 || true"],
      "linux": {
        "command": "/bin/sh",
        "args": ["-c", "fuser -k 4200/tcp >/dev/null 2>&1 || true"]
      },
      "problemMatcher": []
    },
    {
      "label": "kill ng test",
      "type": "shell",
      "command": "/bin/sh",
      "args": ["-c", "fuser -k 9876/tcp >/dev/null 2>&1 || true"],
      "linux": {
        "command": "/bin/sh",
        "args": ["-c", "fuser -k 9876/tcp >/dev/null 2>&1 || true"]
      },
      "problemMatcher": []
    },
    {
      "label": "Angular Serve",
      "type": "npm",
      "script": "watch:all",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": true
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "typescript",
          "source": "Angular Serve - TS",
          "fileLocation": ["relative", "${workspaceFolder}"],
          "applyTo": "allDocuments",
          "pattern": {
            "regexp": "Error: ([^\\s].*)[\\(:](\\d+)[,:](\\d+)(?:\\):\\s+|\\s+-\\s+)(error|warning|info)\\s+TS(\\d+)\\s*:\\s*(.*)",
            "file": 1,
            "line": 2,
            "column": 3,
            "severity": 4,
            "code": 5,
            "message": 6
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^.*Initial chunk files.*$",
            "endsPattern": "^.*(?:Compiled successfully|Application bundle generation complete|compiled successfully|Angular Live Development Server is listening).*$"
          }
        },
        {
          "owner": "ng-cli",
          "source": "Angular Serve - NG",
          "fileLocation": "absolute",
          "applyTo": "allDocuments",
          "pattern": {
            "regexp": "^\\s*(?:Error: )?([^\\s].*)[\\(:](\\d+)[,:](\\d+)(?:\\):\\s+|\\s+-\\s+)(error|warning|info)\\s+NG(\\d+)\\s*:\\s*(.*) \\n?in (.*)@(\\d+):(\\d+)$",
            "file": 7,
            "line": 8,
            "column": 9,
            "severity": 4,
            "code": 5,
            "message": 6
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": ".*(Compiled successfully|Application bundle generation complete|compiled successfully).*"
          }
        }
      ]
    }
  ]
}
